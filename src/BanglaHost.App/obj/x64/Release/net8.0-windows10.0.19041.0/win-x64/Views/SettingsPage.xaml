<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="660" HorizontalAlignment="Left">
            <TextBlock x:ConnectionId='2' x:Name="SettingsTitle" Text="Settings" FontSize="26" FontWeight="SemiBold"/>

            <!-- Domains, ports & defaults (editable) -->
            <Border BorderThickness="1" CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock x:ConnectionId='20' x:Name="DomainsHeader" Text="Domains, ports &amp; defaults" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox x:ConnectionId='32'  x:Name="TldBox"   Header="TLD" Width="120"/>
                        <NumberBox x:ConnectionId='33' x:Name="HttpBox"  Header="HTTP port"  Width="130" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact"/>
                        <NumberBox x:ConnectionId='34' x:Name="HttpsBox" Header="HTTPS port" Width="130" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:ConnectionId='30' x:Name="PhpDefBox" Header="Default PHP" Width="120"/>
                        <ComboBox x:ConnectionId='31' x:Name="WebDefBox" Header="Default web server" Width="160">
                            <ComboBoxItem Content="nginx"/>
                            <ComboBoxItem Content="apache"/>
                        </ComboBox>
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='28' x:Name="RootBox" Header="Sites root" Grid.Column="0"/>
                        <Button x:ConnectionId='29' x:Name="BrowseRootBtn" Content="Browse…" Grid.Column="1"                          VerticalAlignment="Bottom"/>
                    </Grid>
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock x:ConnectionId='26' x:Name="DataDirLabel" Text="Data directory" Opacity="0.7" VerticalAlignment="Center"/><TextBlock x:ConnectionId='27' x:Name="HomeText" Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center"/></Grid>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:ConnectionId='22' x:Name="SaveBtn" Content="Save"                    Style="{StaticResource AccentButtonStyle}"/>
                        <Button x:ConnectionId='23' x:Name="RevertBtn" Content="Revert"                     />
                        <ProgressRing x:ConnectionId='24' x:Name="Busy" IsActive="False" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock x:ConnectionId='25' x:Name="SaveStatus" Opacity="0.7" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:ConnectionId='21' x:Name="TopologyHint" Text="Changing the TLD or ports re-renders all vhosts and restarts nginx. After a TLD change, re-issue HTTPS per site." Opacity="0.55" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- App behavior -->
            <Border BorderThickness="1" CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock x:ConnectionId='7' x:Name="AppBehaviorHeader" Text="App behavior" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ToggleSwitch x:ConnectionId='8' x:Name="AutostartToggle" Header="Start BanglaHost at login" OffContent="Off" OnContent="On"                            />
                    <ToggleSwitch x:ConnectionId='9' x:Name="StartSvcToggle" Header="Start services when BanglaHost launches" OffContent="Off" OnContent="On"                       />
                    <ToggleSwitch x:ConnectionId='10' x:Name="TrayToggle" Header="Keep running in the system tray when the window is closed"
                                  OffContent="Off — closing the window quits BanglaHost" OnContent="On — sites stay up in the background"                       />
                    <ToggleSwitch x:ConnectionId='11' x:Name="AutoUpdateToggle" Header="Automatically check for updates" OffContent="Off" OnContent="On"                       />
                    <ToggleSwitch x:ConnectionId='12' x:Name="BanglaLanguageToggle" Header="Bengali UI Language (বাংলা ভাষা)" OffContent="English" OnContent="বাংলা"                           />
                    <ComboBox x:ConnectionId='13' x:Name="ThemeBox" Header="App Theme"                                  Width="220">
                        <ComboBoxItem Content="Default"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <NumberBox x:ConnectionId='18' x:Name="DashSizeBox" Header="Dashboard list — sites per page" Width="220"
                                   Minimum="1" Maximum="500" SpinButtonPlacementMode="Inline"                                />
                        <NumberBox x:ConnectionId='19' x:Name="SitesSizeBox" Header="Sites page — sites per page" Width="220"
                                   Minimum="1" Maximum="500" SpinButtonPlacementMode="Inline"                                />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:ConnectionId='15' x:Name="OpenDataFolderBtn" Content="Open data folder"                         />
                        <Button x:ConnectionId='16' x:Name="UpdateBtn" Content="Check for updates"                           />
                        <ProgressRing x:ConnectionId='17' x:Name="UpdateBusy" IsActive="False" Width="18" Height="18" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:ConnectionId='14' x:Name="UpdateStatus" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border BorderThickness="1" CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Image x:ConnectionId='3' x:Name="LogoImg" Width="64" Height="64" VerticalAlignment="Top"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="BanglaHost" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock x:ConnectionId='4' x:Name="Version" Opacity="0.7" FontSize="13"/>
                        <TextBlock x:ConnectionId='5' x:Name="AboutDesc" Text="Your own free local web server for Windows" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Margin="0,6,0,0" Opacity="0.85" FontSize="12">
                            <Run x:ConnectionId='6' x:Name="BuiltByText" Text="Built with love by"/> <Run Text="Mohammad Sheikh Shahinur Rahman" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

