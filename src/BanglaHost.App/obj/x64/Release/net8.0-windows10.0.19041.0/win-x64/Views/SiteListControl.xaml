<?xml version="1.0" encoding="utf-8"?>
<UserControl x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.SiteListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BanglaHost.App.Views"
    xmlns:core="using:BanglaHost.Core">

    <!-- Grid (not StackPanel) so the list row is height-bounded when the control is given a
         bounded height (Sites page) — that lets the ListView's built-in ScrollViewer engage and
         virtualize. When the control is placed in an unbounded container (the Dashboard's outer
         ScrollViewer), the star row measures as content-size, so it still shows every row. -->
    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Show + search -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:ConnectionId='38'                                     Opacity="0.7" VerticalAlignment="Center"/>
                <ComboBox x:ConnectionId='39' x:Name="ShowBox" Width="84"                                >
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="15"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                    <ComboBoxItem Content="All"/>
                </ComboBox>
                <ProgressRing x:ConnectionId='40' x:Name="Busy" Width="18" Height="18" IsActive="False" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox x:ConnectionId='37' x:Name="SearchBox"                                                  Width="220" HorizontalAlignment="Right"                             />
        </Grid>

        <!-- list -->
        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <TextBlock x:ConnectionId='9' x:Name="Empty" Text="No sites yet." Opacity="0.6" Padding="10" Visibility="Collapsed"/>
                <ListView x:ConnectionId='10' x:Name="List" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate                           >
                            <Grid x:ConnectionId='12' Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:ConnectionId='13' Grid.Column="0" Width="9" Height="9"                          VerticalAlignment="Center"/>
                                <TextBlock x:ConnectionId='14' Grid.Column="1"                      FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <HyperlinkButton x:ConnectionId='15' Grid.Column="2"                                                   VerticalAlignment="Center"/>
                                <Border Grid.Column="3" VerticalAlignment="Center" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock x:ConnectionId='36'                       FontSize="11" Opacity="0.8"/>
                                </Border>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2">
                                    <Button x:ConnectionId='16'                                                                                               ><FontIcon Glyph="&#xE774;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='17'                                                                                                 ><FontIcon Glyph="&#xE8B7;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='18'                                                                                               ><FontIcon Glyph="&#xE9F9;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='19'                                                                                                           ><FontIcon Glyph="&#xE7E8;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='20'                                                                                                         ><FontIcon Glyph="&#xE72D;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='21'                                                                                                                                          ><FontIcon Glyph="&#xE72E;" FontSize="14"/></Button>
                                    <Button x:ConnectionId='22'                                                      >
                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem x:ConnectionId='23'                                                                                              />
                                                <MenuFlyoutItem x:ConnectionId='24'                                                                                               />
                                                <MenuFlyoutItem x:ConnectionId='25'                                                                                       />
                                                <MenuFlyoutItem x:ConnectionId='26'                                                                                         />
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:ConnectionId='27'                                                                                        />
                                                <MenuFlyoutItem x:ConnectionId='28'                                                                                   />
                                                <MenuFlyoutItem x:ConnectionId='29'                                                                                     />
                                                <MenuFlyoutItem x:ConnectionId='30'                                                                                           />
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutSubItem x:ConnectionId='31'                                           >
                                                    <MenuFlyoutItem x:ConnectionId='34' Text="WordPress"                                                   />
                                                    <MenuFlyoutItem x:ConnectionId='35' Text="Laravel"                                                 />
                                                </MenuFlyoutSubItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:ConnectionId='32'                                                                                                 />
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:ConnectionId='33'                                                                               />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- pagination + jump -->
        <StackPanel x:ConnectionId='2' x:Name="Pager" Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Visibility="Collapsed">
            <Button x:ConnectionId='3' x:Name="PrevBtn"                                                                         ><FontIcon Glyph="&#xE76B;" FontSize="12"/></Button>
            <TextBlock x:ConnectionId='4' x:Name="PageLabel" VerticalAlignment="Center" MinWidth="90" TextAlignment="Center"/>
            <Button x:ConnectionId='5' x:Name="NextBtn"                                                                         ><FontIcon Glyph="&#xE76C;" FontSize="12"/></Button>
            <TextBlock x:ConnectionId='6'                                      VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0"/>
            <NumberBox x:ConnectionId='7' x:Name="JumpBox" Width="84" SpinButtonPlacementMode="Hidden" Minimum="1"/>
            <Button x:ConnectionId='8'                                                      />
        </StackPanel>
    </Grid>
</UserControl>

