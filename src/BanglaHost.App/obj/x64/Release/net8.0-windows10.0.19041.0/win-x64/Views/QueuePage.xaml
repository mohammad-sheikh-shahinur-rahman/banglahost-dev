<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Message Queues" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="Monitor and manage RabbitMQ, Kafka, and Beanstalkd services."/>
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="20">
                <!-- RabbitMQ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="RabbitMQ" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='6' x:Name="RabbitStatus" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.7"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button x:ConnectionId='7' Content="Open Management UI"                        x:Name="RabbitUiBtn" IsEnabled="False"/>
                        <Button x:ConnectionId='8' Content="Restart"                            />
                    </StackPanel>
                </Grid>

                <MenuFlyoutSeparator/>

                <!-- Beanstalkd -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Beanstalkd" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='4' x:Name="BeanstalkStatus" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.7"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button x:ConnectionId='5' Content="Restart"                               />
                    </StackPanel>
                </Grid>

                <MenuFlyoutSeparator/>

                <!-- Kafka -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Kafka" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='2' x:Name="KafkaStatus" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.7"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button x:ConnectionId='3' Content="Restart"                           />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>

