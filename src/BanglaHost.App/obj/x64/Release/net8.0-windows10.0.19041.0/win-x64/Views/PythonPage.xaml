<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.PythonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BanglaHost.App.Views">

    <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Python" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="A managed Python interpreter + supervised Python-app sites (Flask / Django / FastAPI / Gunicorn / Uvicorn)"/>
        </StackPanel>

        <TextBlock Text="Interpreter" FontSize="16" FontWeight="SemiBold"/>
        <Border BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:ConnectionId='26' x:Name="InterpStatus" VerticalAlignment="Center" Text="checking…"/>
                <Button x:ConnectionId='27' x:Name="InstallPyBtn" Content="Install Python"                         Style="{StaticResource AccentButtonStyle}"/>
                <ProgressRing x:ConnectionId='28' x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid>
            <TextBlock Text="Python apps" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button x:ConnectionId='25' Content="Add Python app"                      HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
        <Border BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel>
                <Grid Padding="8,6" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Show" VerticalAlignment="Center" Opacity="0.7"/>
                        <ComboBox x:ConnectionId='24' x:Name="AppPageSizeBox" Width="80"                                       />
                    </StackPanel>
                    <TextBox x:ConnectionId='23' Grid.Column="2" x:Name="AppSearchBox" PlaceholderText="search…" Width="200"                                />
                </Grid>
                <TextBlock x:ConnectionId='2' x:Name="EmptyApps" Text="No Python apps yet. Click “Add Python app”." Opacity="0.6" Padding="10" Visibility="Collapsed"/>
                <ListView x:ConnectionId='3' x:Name="AppsList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate                            >
                            <Grid x:ConnectionId='9' Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:ConnectionId='10' Grid.Column="0" Width="9" Height="9"                          VerticalAlignment="Center"/>
                                <TextBlock x:ConnectionId='11' Grid.Column="1"                      FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:ConnectionId='12' Grid.Column="2"                        Opacity="0.7" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                    <Button x:ConnectionId='13' Content="Open"                                         />
                                    <Button x:ConnectionId='14' Content="Start"                                           />
                                    <Button x:ConnectionId='15' Content="Stop"                                          />
                                    <Button ToolTipService.ToolTip="More">
                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem x:ConnectionId='16' Text="Restart"                                             />
                                                <MenuFlyoutItem x:ConnectionId='17' Text="pip install"                                         />
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:ConnectionId='18' Text="Open folder"                                            />
                                                <MenuFlyoutItem x:ConnectionId='19' Text="Open in code editor"                                            />
                                                <MenuFlyoutItem x:ConnectionId='20' Text="Open terminal here"                                              />
                                                <MenuFlyoutItem x:ConnectionId='21' Text="View logs"                                          />
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:ConnectionId='22' Text="Remove"                                            />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Grid x:ConnectionId='4' x:Name="AppPager" Padding="8,8" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button x:ConnectionId='5' x:Name="AppPrevBtn"                      ><FontIcon Glyph="&#xE76B;" FontSize="12"/></Button>
                        <TextBlock x:ConnectionId='6' x:Name="AppPageLabel" VerticalAlignment="Center" Opacity="0.8"/>
                        <Button x:ConnectionId='7' x:Name="AppNextBtn"                      ><FontIcon Glyph="&#xE76C;" FontSize="12"/></Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Page>

