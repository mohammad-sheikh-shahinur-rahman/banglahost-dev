<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.SitesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BanglaHost.App.Views"
    xmlns:vm="using:BanglaHost.App.ViewModels">

    <Grid x:ConnectionId='2' x:Name="RootGrid" Padding="24" RowSpacing="16"                                 >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:ConnectionId='3' x:Name="PageTitle" Grid.Row="0" Text="Sites" FontSize="26" FontWeight="SemiBold"/>
        
        <InfoBar Grid.Row="1" IsOpen="{Binding StatusOpen, Mode=TwoWay}" Message="{Binding StatusMessage}" Severity="{Binding StatusSeverity}" />

        <Border Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid RowSpacing="12" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                    <TextBox x:ConnectionId='20' x:Name="SiteNameBox" Text="{Binding NewSiteName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Site name" Width="150"/>
                    <ComboBox x:ConnectionId='21' x:Name="BlueprintBox" Header="Blueprint" ItemsSource="{Binding Blueprints}" SelectedItem="{Binding SelectedBlueprint, Mode=TwoWay}" Width="120"/>
                    <ComboBox x:ConnectionId='22' x:Name="PhpBox" Header="PHP" ItemsSource="{Binding PhpVersions}" SelectedItem="{Binding SelectedPhp, Mode=TwoWay}" Width="80"/>
                    <ComboBox x:ConnectionId='23' x:Name="CmsBox" Header="CMS / Type" ItemsSource="{Binding CmsOptions}" SelectedItem="{Binding SelectedCms, Mode=TwoWay}" Width="120"/>
                    <ComboBox x:ConnectionId='24' x:Name="ServerBox" Header="Server" ItemsSource="{Binding WebServers}" SelectedItem="{Binding SelectedWebServer, Mode=TwoWay}" Width="90"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                    <CheckBox x:ConnectionId='18' x:Name="HttpsToggle" Content="HTTPS" IsChecked="{Binding EnableHttps, Mode=TwoWay}" Margin="0,0,0,4"/>
                    <Button x:ConnectionId='19' x:Name="AddSiteBtn" Content="Add site" Command="{Binding AddSiteCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
                    <ProgressRing IsActive="{Binding IsBusy}" Width="20" Height="20" Margin="4,0,0,6" VerticalAlignment="Bottom"/>
                </StackPanel>

                <StackPanel x:ConnectionId='14' Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8"                                                                                     >
                    <TextBox x:ConnectionId='15' x:Name="RootPathBox" Text="{Binding CustomRootPath, Mode=TwoWay}" PlaceholderText="Project folder path" Width="400" IsReadOnly="True"/>
                    <Button x:ConnectionId='16' x:Name="BrowseBtn" Content="Browse…" Command="{Binding BrowseFolderCommand}" VerticalAlignment="Bottom"/>
                    <TextBlock x:ConnectionId='17' x:Name="CustomModeHint" Text="Point at any existing project folder — nothing is overwritten." Opacity="0.65" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <TextBlock x:ConnectionId='4' x:Name="EmptySitesText" Text="No sites yet. Add one above."
                                                                                                          
                           VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6"/>
                <ListView x:ConnectionId='5' x:Name="SitesListView" ItemsSource="{Binding Sites}" Tag="{Binding}" SelectionMode="None"
                                                                                                                >
                    <ListView.ItemTemplate>
                        <DataTemplate                             >
                            <Grid x:ConnectionId='7' Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock x:ConnectionId='8' Grid.Column="0"                          FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <HyperlinkButton x:ConnectionId='9' Grid.Column="1"                                                   VerticalAlignment="Center"/>
                                
                                <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock x:ConnectionId='13'                       FontSize="11" Opacity="0.8"/>
                                </Border>
                                
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                    <Button x:ConnectionId='10' Command="{Binding Path=Tag.FixHostsCommand, ElementName=SitesListView}"                             ToolTipService.ToolTip="Fix DNS (hosts file)">
                                        <FontIcon Glyph="&#xE774;" FontSize="14"/>
                                    </Button>
                                    <Button x:ConnectionId='11' Command="{Binding Path=Tag.EditSiteCommand, ElementName=SitesListView}"                             ToolTipService.ToolTip="Edit">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                    <Button x:ConnectionId='12' Command="{Binding Path=Tag.DeleteSiteCommand, ElementName=SitesListView}"                             ToolTipService.ToolTip="Delete">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

