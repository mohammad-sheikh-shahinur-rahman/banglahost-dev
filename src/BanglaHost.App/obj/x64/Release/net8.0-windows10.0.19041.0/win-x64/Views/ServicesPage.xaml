<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BanglaHost.App.Views">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock x:ConnectionId='30' x:Name="PageTitle" Text="Services" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Install downloads portable builds on demand into BanglaHost's own bin folder."
                               Opacity="0.7"/>
                </StackPanel>
                <ProgressRing x:ConnectionId='29' x:Name="Busy" IsActive="False" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <Border x:ConnectionId='2' x:Name="OpBanner" Visibility="Collapsed" CornerRadius="8" Padding="12" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <StackPanel Spacing="6">
                    <Grid>
                        <TextBlock x:ConnectionId='26' x:Name="OpName" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <TextBlock x:ConnectionId='27' x:Name="OpPct" Opacity="0.7" VerticalAlignment="Center"/>
                            <Button x:ConnectionId='28' x:Name="OpDismiss" Content="Dismiss"                         Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:ConnectionId='24' x:Name="OpBar" Minimum="0" Maximum="100"/>
                    <TextBlock x:ConnectionId='25' x:Name="OpMsg" Opacity="0.7" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <ItemsControl x:ConnectionId='3' x:Name="Groups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate                            >
                        <Border x:ConnectionId='5' CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="2">
                                <TextBlock x:ConnectionId='6'                                 FontWeight="SemiBold" Opacity="0.8" Margin="4,2,0,6"/>
                                <ItemsControl x:ConnectionId='7'                            >
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate                          >
                                            <Grid x:ConnectionId='9' Padding="6,5" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse x:ConnectionId='10' Grid.Column="0" Width="9" Height="9"                          VerticalAlignment="Center"/>
                                                <TextBlock x:ConnectionId='11' Grid.Column="1"                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock x:ConnectionId='21'                            Opacity="0.6" FontSize="12"/>
                                                    <Border x:ConnectionId='22' Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="4,1"                             >
                                                        <TextBlock x:ConnectionId='23'                         FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <ToggleButton x:ConnectionId='12' Grid.Column="3"                                                                          
                                                              ToolTipService.ToolTip="Start automatically" VerticalAlignment="Center" Padding="6"
                                                                                             >
                                                    <FontIcon Glyph="&#xE734;" FontSize="13"/>
                                                </ToggleButton>
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6">
                                                    <Button x:ConnectionId='13' Content="Install"                                                                           />
                                                    <Button x:ConnectionId='14' Content="Start"                                                                                                         />
                                                    <Button x:ConnectionId='15' Content="Stop"                                                                                                         />
                                                    <Button x:ConnectionId='16' ToolTipService.ToolTip="More"                               >
                                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuFlyoutItem x:ConnectionId='17' Text="View log"                                            />
                                                                <MenuFlyoutItem x:ConnectionId='18' Text="Edit php.ini"                                                                      />
                                                                <MenuFlyoutSeparator/>
                                                                <MenuFlyoutItem x:ConnectionId='19' Text="Reinstall (update)"                                        />
                                                                <MenuFlyoutItem x:ConnectionId='20' Text="Uninstall"                                           />
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>

