<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.TerminalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24,24,24,12" Spacing="4">
            <TextBlock Text="BanglaHost Terminal" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="Environment pre-configured with PHP, MySQL, Composer, and Node.js."/>
        </StackPanel>

        <Border Grid.Row="1" Margin="24,0,24,12" CornerRadius="8" Background="Black" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <ScrollViewer x:ConnectionId='4' x:Name="OutputScroll" Padding="12">
                <TextBlock x:ConnectionId='5' x:Name="OutputBlock" FontFamily="Consolas" FontSize="14" Foreground="LightGray" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Padding="24,0,24,24" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:ConnectionId='2' x:Name="InputBox" PlaceholderText="Type a command (e.g. php -v) and press Enter..."
                     FontFamily="Consolas"                           />
            <Button x:ConnectionId='3' Grid.Column="1" Content="Clear"                    />
        </Grid>
    </Grid>
</Page>

