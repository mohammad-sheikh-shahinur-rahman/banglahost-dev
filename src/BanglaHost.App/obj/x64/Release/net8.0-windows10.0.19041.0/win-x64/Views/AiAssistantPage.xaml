<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.AiAssistantPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="AI Assistant (Ollama)" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock x:ConnectionId='9' x:Name="OllamaStatus" Opacity="0.7" Text="Checking Ollama..."/>
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox x:ConnectionId='6' x:Name="ModelBox" Width="200" PlaceholderText="Select Model"/>
                <Button x:ConnectionId='7' Content="Refresh Models"                            />
                <TextBlock x:ConnectionId='8' x:Name="ModelStatus" VerticalAlignment="Center" Opacity="0.6"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ScrollViewer x:ConnectionId='4' x:Name="ChatScroll">
                <TextBlock x:ConnectionId='5' x:Name="ChatHistory" TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="14"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="8" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:ConnectionId='2' x:Name="InputBox" PlaceholderText="Ask me anything..."                           />
            <Button x:ConnectionId='3' Grid.Column="1" Content="Send" Style="{StaticResource AccentButtonStyle}"                   />
        </Grid>
    </Grid>
</Page>

