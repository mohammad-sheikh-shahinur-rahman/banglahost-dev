<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.CronPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Spacing="4">
                <TextBlock Text="Cron Scheduler" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Opacity="0.7" Text="Manage background jobs (synced with Windows Task Scheduler)."/>
            </StackPanel>
            <Button x:ConnectionId='5' Content="Add Job"                      Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>

        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <TextBlock Text="Jobs will run every minute in the background even when BanglaHost is closed."/>
        </Border>

        <ListView x:ConnectionId='2' Grid.Row="2" x:Name="JobList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Expression}" Opacity="0.8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding LastRun}" Opacity="0.7" VerticalAlignment="Center"/>
                        <Button x:ConnectionId='4' Grid.Column="3"                      Tag="{Binding Name}" Content="Delete"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

