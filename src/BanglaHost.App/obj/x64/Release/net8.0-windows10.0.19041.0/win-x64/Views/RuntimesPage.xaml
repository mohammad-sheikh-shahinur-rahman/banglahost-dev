<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="BanglaHost.App.Views.RuntimesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >
    <StackPanel Padding="24" Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Runtimes &amp; Containers" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="Check system status for Go, Rust, and Docker."/>
        </StackPanel>

        <Border BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="16">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Go:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:ConnectionId='8' x:Name="GoVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button x:ConnectionId='9' Grid.Column="2" Content="Download Go"                         />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Rust (cargo):" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:ConnectionId='6' x:Name="RustVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button x:ConnectionId='7' Grid.Column="2" Content="Download Rust"                           />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Docker:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:ConnectionId='4' x:Name="DockerVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button x:ConnectionId='5' Grid.Column="2" Content="Download Docker"                             />
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button x:ConnectionId='2' Content="Refresh Status"                      />
                    <ProgressRing x:ConnectionId='3' x:Name="Busy" IsActive="False" Width="20" Height="20" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>

