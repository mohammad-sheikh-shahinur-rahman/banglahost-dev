<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.GitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Git Manager" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Text="GitHub Connection" FontSize="13" Opacity="0.6"/>
        </StackPanel>

        <!-- GitHub Auth Card -->
        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="ConnectBtn" Content="Connect with GitHub"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="Connect_Click"/>
                    <Button x:Name="DisconnectBtn" Content="Disconnect" Visibility="Collapsed"
                            Click="Disconnect_Click"/>
                    <ProgressRing x:Name="AuthBusy" IsActive="False" Width="20" Height="20"/>
                </StackPanel>
                <TextBlock x:Name="AuthStatus" Text="" FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                <StackPanel x:Name="UserPanel" Visibility="Collapsed" Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE77B;" FontSize="16"/>
                    <TextBlock x:Name="UserName" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:Name="UserLogin" VerticalAlignment="Center" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Clone Repository Card -->
        <Border Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="12">
                <TextBlock Text="Clone Repository" FontWeight="SemiBold" FontSize="15"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Repository URL" FontSize="12" Opacity="0.7"/>
                        <TextBox x:Name="RepoUrl" PlaceholderText="https://github.com/user/repo.git"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Local Folder Name" FontSize="12" Opacity="0.7"/>
                        <TextBox x:Name="FolderName" PlaceholderText="folder-name"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <ProgressRing x:Name="CloneBusy" IsActive="False" Width="20" Height="20"/>
                    <Button x:Name="CloneBtn" Content="Clone Repository"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="Clone_Click"/>
                </StackPanel>
                <TextBlock x:Name="CloneStatus" Text="" FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Active Repositories Card -->
        <Border Grid.Row="3" BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Active Repositories" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                    <Button Content="Refresh" Click="Refresh_Click" Padding="8,4"/>
                </StackPanel>
                <ListView x:Name="RepoList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Branch}" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11"
                                           VerticalAlignment="Center" Opacity="0.7"/>
                                <Button Grid.Column="2" Content="Open" Tag="{Binding Path}"
                                        Click="OpenRepo_Click" Padding="8,4" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="NoReposText" Text="No git repositories found in your sites root."
                           Opacity="0.5" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- GitHub Repos Card (when connected) -->
        <Border Grid.Row="4" x:Name="GhReposCard" BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Visibility="Collapsed">
            <StackPanel Spacing="10">
                <TextBlock Text="Your GitHub Repositories" FontWeight="SemiBold" FontSize="15"/>
                <ListView x:Name="GhRepoList" SelectionMode="None" MaxHeight="220">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Clone" Tag="{Binding CloneUrl}"
                                        Click="QuickClone_Click" Padding="8,4" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing x:Name="GhBusy" IsActive="False" Width="24" Height="24" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="5" x:Name="StatusBar" Text="" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
    </Grid>
</Page>
